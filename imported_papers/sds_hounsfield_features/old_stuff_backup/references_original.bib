@article{suka_aryana_important_2023,
	title = {The {Important} {Role} of {Intermuscular} {Adipose} {Tissue} on {Metabolic} {Changes} {Interconnecting} {Obesity}, {Ageing} and {Exercise}: {A} {Systematic} {Review}},
	volume = {19},
	copyright = {https://creativecommons.org/licenses/by-nc/4.0/},
	issn = {1758-3772},
	shorttitle = {The {Important} {Role} of {Intermuscular} {Adipose} {Tissue} on {Metabolic} {Changes} {Interconnecting} {Obesity}, {Ageing} and {Exercise}},
	url = {https://www.touchendocrinology.com/obesity/journal-articles/the-important-role-of-intermuscular-adipose-tissue-on-metabolic-changes-interconnecting-obesity-ageing-and-exercise-a-systematic-review/},
	doi = {10.17925/EE.2023.19.1.54},
	abstract = {As age increases, adipose tissue infiltrates muscle tissue and leads to sarcopenia. When excessive accumulation of adipose tissue accompanied progressive decrease in lean body mass especially visceral fat, termed as sarcopenic obesity (SO) and related metabolic intermuscular adipose tissue (IMAT) is an ectopic tissue found between muscle groups, and is distinct from subcutaneous adipose tissue. Until now, the association between IMAT and metabolic health was not understood. This study is the first systematic review assessing the association between IMAT and metabolic health. The PubMed, Science Direct and Cochrane databases were searched for studies reporting IMAT and metabolic risk. The descriptions of the extracted data are guided by the Preferred Reporting Items for Systematic Reviews (PRISMA) statement with a Grading of Recommendations Assessment, Development and Evaluation approach. This study is registered at PROSPERO (identifier: CRD42022337518). Six studies were pooled and reviewed using critical appraisal by the Newcastle Ottawa Scale and Centre for Evidence-Based Medicine checklist. Two clinical trials and four observational trials were included. Our results reveal that IMAT is associated with metabolic risk, especially in older adults and patients with obesity. However, in a person with abdominal obesity, VAT has a more significant role in metabolic risk than IMAT. The largest decrease in IMAT was achieved by combining aerobic with resistance training.},
	language = {en},
	number = {1},
	urldate = {2025-02-06},
	journal = {European Endocrinology},
	author = {Suka Aryana, I Gusti Putu and {Geriatric Division, Department of Internal Medicine, Faculty of Medicine, Udayana University/Prof. I Goesti Ngoerah Gde Ngoerah Teaching Hospital, Denpasar, Bali, Indonesia} and Paulus, Ivana Beatrice and {Wangaya General Hospital, Denpasar, Bali, Indonesia} and Kalra, Sanjay and {Bharti Hospital, Karnal, India} and {Department of Research, Chandigarh University, Chandigarh, India} and Daniella, Dian and {Department of Internal Medicine, Faculty of Medicine, Udayana University/ I Goesti Ngoerah Gde Ngoerah Teaching Hospital, Bali, Denpasar, Indonesia} and Kuswardhani, Raden Ayu Tuty and {Geriatric Division, Department of Internal Medicine, Faculty of Medicine, Udayana University/ I Goesti Ngoerah Gde Ngoerah Teaching Hospital, Denpasar, Bali, Indonesia} and Suastika, Ketut and {Division of Endocrinology and Metabolism, Department of Internal Medicin, Faculty of Medicine, Udayana University/ I Goesti Ngoerah Gde Ngoerah Teaching Hospital, Denpasar, Bali, Indonesia} and Wibisono, Sony and {Division of Endocrinology and Metabolism, Airlangga University, Soetomo Teaching Hospital, Surabaya, Indonesia}},
	year = {2023},
	pages = {54},
}

